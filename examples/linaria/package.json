{
  "name": "example-linaria",
  "version": "9.0.46",
  "private": true,
  "scripts": {
    "start": "rsbuild dev",
    "start:webpack": "webpack serve --mode=development",
    "start:prod": "serve ./dist",
    "build": "rsbuild build",
    "build:webpack": "webpack --mode=production",
    "build:server": "RSBUILD_TARGET=node rsbuild build",
    "build:clean": "rm -rf dist && rm -rf server_assets",
    "build:analyze": "RSBUILD_ANALYZE=true rsbuild build",
    "build:profile": "RSBUILD_PROFILE=true rsbuild build",
    "pkgcheck": "RSBUILD_CHECK=nobuild rsbuild build",
    "test": "echo \"Error: no test specified\" && exit 1",
    "test:ci": "echo \"Error: no test specified\"",
    "test:type": "tsc --noEmit",
    "devtest:validate": "exit 0",
    "devtest:ci": "yarn g:devtest start http://localhost:8080 devtest:validate"
  },
  "devDependencies": {
    "@anansi/babel-preset": "^6.2.26",
    "@anansi/browserslist-config": "^1.7.4",
    "@anansi/eslint-plugin": "^1.0.73",
    "@anansi/rspack-config": "workspace:*",
    "@anansi/webpack-config": "^21.1.18",
    "@babel/core": "^7.21.3",
    "@rsbuild/core": "^1.5.0",
    "@types/babel__core": "^7.20.0",
    "@types/eslint": "^9.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/react-router-dom": "5.3.3",
    "babel-loader": "10.1.1",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "react-refresh": "0.18.0",
    "serve": "14.2.6",
    "webpack": "5.106.2",
    "webpack-cli": "^7.0.0",
    "webpack-dev-server": "^5.0.0"
  },
  "dependencies": {
    "@babel/plugin-transform-modules-commonjs": "7.28.6",
    "@babel/runtime-corejs3": "7.29.2",
    "@linaria/core": "7.0.0",
    "@linaria/react": "7.0.1",
    "classnames": "2.5.1",
    "core-js": "3.49.0",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "browserslist": [
    "extends @anansi/browserslist-config"
  ],
  "peerDependencies": {
    "@types/react": "^17.0.40 || ^18.0.0 || ^19.0.0",
    "@types/react-dom": "^17.0.40 || ^18.0.0 || ^19.0.0"
  }
}
