  "description": "Production ready Rsbuild config for React",
  "main": "lib/index.js",
  "types": "./index.d.ts",
  "scripts": {
    "test": "jest",
    "test:ci": "jest --ci --coverage",
    "build:lib": "BROWSERSLIST_ENV=node18 yarn g:babel --out-dir lib",
    "build": "run build:lib",
    "dev": "run build:lib -w",
    "build:clean": "yarn g:rimraf lib",
    "prepare": "run build:clean && run build",
    "prepack": "run prepare"
  },
